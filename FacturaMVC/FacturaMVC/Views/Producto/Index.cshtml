@model List<FacturaMVC.Models.Producto>

@{
    ViewData["Title"] = "Productos";
}

<h2 class="mb-3">Productos</h2>

<a asp-action="Crear" class="btn btn-success mb-3">Registrar nuevo producto</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Nombre</td>
                <td>@p.Precio.ToString("C")</td>
                <td>
                    <a asp-action="Detalle" asp-route-id="@p.Id" class="btn btn-primary btn-sm">Ver detalle</a>
                    <a asp-action="Editar" asp-route-id="@p.Id" class="btn btn-warning btn-sm">Editar</a>
                    <form asp-action="Eliminar" asp-route-id="@p.Id" method="post" style="display:inline">
                        <button type="submit" class="btn btn-danger btn-sm"
                                onclick="return confirm('¿Seguro que desea eliminar este producto?')">
                            Eliminar
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>